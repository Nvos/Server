# Copy this file to ".env" (same folder as docker-compose.yml) and edit the values.
# Every variable below is required on first boot — the entrypoint refuses to start
# if any of the non-optional ones are blank.

# ---- Database -------------------------------------------------------------
POSTGRES_DB=cot
POSTGRES_USER=martiuser
POSTGRES_PASSWORD=change_me_db
# Must resolve to the 'takdb' service on port 5432:
POSTGRES_URL=jdbc:postgresql://takdb:5432/cot

# ---- Certificate Authority (auto-generated on first boot) -----------------
# These become the DN fields of your self-signed CA + issued certs.
CA_NAME=takserver-local-ca
CA_PASS=change_me_ca
STATE=PL
CITY=Bialystok
ORGANIZATION=TAK
ORGANIZATIONAL_UNIT=takserver

# ---- TAK Server instance certificate --------------------------------------
TAKSERVER_CERT_PASS=change_me_server

# ---- Admin (management) client certificate --------------------------------
# After first boot, import takdata/certs/files/<ADMIN_CERT_NAME>.p12 into your
# browser using ADMIN_CERT_PASS, then open https://localhost:8443
ADMIN_CERT_NAME=admin
ADMIN_CERT_PASS=change_me_admin

# ---- Optional JVM heap caps in MB -----------------------------------------
# If left unset, setenv.sh derives them from the container's visible RAM.
#CONFIG_MAX_HEAP=512
#MESSAGING_MAX_HEAP=2048
#API_MAX_HEAP=2048
#PLUGIN_MANAGER_MAX_HEAP=512
